rules_version = '2';

// ──────────────────────────────────────────────────────────────────────
// WELLlife Care — Firestore security rules
//
// Model: each user owns everything under users/{uid}. Nobody else can
// read or write any of their data, including admins (until you build an
// admin role with custom claims).
//
// To deploy: copy the entire contents of this file into the Firebase
// Console → Firestore → Rules tab → Publish.
//
// Or, if you install Firebase CLI later:
//     firebase deploy --only firestore:rules
// ──────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // The user's profile document (users/{uid})
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // All subcollections owned by the user inherit the same rule:
      //   users/{uid}/members/{memberId}
      //   users/{uid}/readings/{readingId}
      //   users/{uid}/messages/{messageId}
      //   …any future collection like /devices, /goals, etc.
      match /{collection}/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Everything else is denied by default — no implicit access.
  }
}
